# Copy to .streamlit/secrets.toml and fill in. That file is gitignored.
# On Streamlit Community Cloud, paste these into Settings → Secrets instead.

# Google Places API (New) — enable "Places API (New)" + billing in Google Cloud.
# Used to geocode ETO/TSIA companies from country-approx to precise coordinates.
GOOGLE_MAPS_API_KEY = ""

# OpenCorporates v0.4 — https://opencorporates.com/api_accounts/new
# Detects new us_az / us_de subsidiary filings (hard migration signal).
OPENCORPORATES_API_TOKEN = ""

# Bill-of-Lading / customs data. ImportYeti has no official public API — point
# this at your provider's endpoint (ImportYeti Enterprise, Panjiva, ImportGenius,
# or Trademo) and adjust _parse_bol() in osint.py to its JSON shape.
IMPORTYETI_API_BASE = ""
IMPORTYETI_API_KEY = ""

# ── Login gate ────────────────────────────────────────────────────────────────
# Each line is  username = "password".  Add at least one to switch the login on;
# leave the whole table out (or empty) to keep the app open to everyone.
[passwords]
admin = "change-me-to-a-strong-password"
# investor = "another-password"
